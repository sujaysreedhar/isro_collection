# Enable Rewrite Engine
RewriteEngine On

# 1. Force lower case (Optional but good for SEO)
# 2. Redirect /item/123/name to item_detail.php?id=123
RewriteRule ^item/([0-9]+)/?.*$ item_detail.php?id=$1 [L,QSA]

# 3. Redirect /category/engineering to search.php?cat=engineering
RewriteRule ^category/([a-z0-9-]+)/?$ search.php?category=$1 [L,QSA]

# 4. Security: Disable directory browsing
Options -Indexes

# 5. Security: Protect config files
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>