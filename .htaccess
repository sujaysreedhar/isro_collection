Options -Indexes

# Enable the rewrite engine
RewriteEngine On

# Set the base path for this subdirectory install
RewriteBase /collection/

# ─── Legacy Module Frontend Pages ────────────────────────────────────────────
RewriteRule ^timeline\.php$ modules/timeline/timeline.php [L,QSA]
RewriteRule ^gallery\.php$ modules/user_galleries/gallery.php [L,QSA]
RewriteRule ^atlas\.php$ modules/postmark_atlas/atlas.php [L,QSA]
RewriteRule ^contact\.php$ modules/contact_us/contact.php [L,QSA]
RewriteRule ^collections\.php$ modules/curated_collections/collections.php [L,QSA]
RewriteRule ^collection\.php$ modules/curated_collections/collection.php [L,QSA]
RewriteRule ^api\.php$ modules/api_export/api.php [L,QSA]
RewriteRule ^people\.php$ modules/people/people.php [L,QSA]
RewriteRule ^person/([a-zA-Z0-9_-]+)/?$ modules/people/person.php?slug=$1 [L,QSA]

# ─── Front Controller ───────────────────────────────────────────
# Allow direct access to real files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [L,QSA]

# ─── Security: block sensitive files ─────────────────────────────────────────
<FilesMatch "\.(sql|env|json|lock)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# ─── PHP settings (XAMPP-compatible) ─────────────────────────────────────────
<IfModule mod_php.c>
    php_flag display_errors Off
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
    php_value extension gd
</IfModule>

# ─── Performance: cache static assets ────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp             "access plus 1 month"
    ExpiresByType image/jpeg             "access plus 1 month"
    ExpiresByType image/png              "access plus 1 month"
    ExpiresByType text/css               "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>